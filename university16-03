#how to return multiple value
def add(): #called function
  n1 = int(input("enter first number "))
  n2 = int(input("enter second number "))
  sum = n1+n2
  mul = n1*n2
  sub = n1-n2
  div = n1/n2
  return sum,mul,sub,div

result = add()
print(result)

